<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.EventWise" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
        <!-- <item name="colorPrimary">@color/my_light_primary</item> -->
    </style>

    <style name="Theme.EventWise" parent="Base.Theme.EventWise" />

    <!-- Splash Screen Theme -->
    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/weird_piss</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <item name="postSplashScreenTheme">@style/Theme.EventWise</item>
    </style>

    <style name="CustomDatePicker" parent="ThemeOverlay.Material3.MaterialCalendar">
        <item name="colorPrimary">@color/forest_green</item>
        <item name="colorOnPrimary">@color/lighter_green</item>
        <item name="colorSurface">@color/lighter_green</item>
        <item name="colorOnSurface">@color/forest_green</item>
        <item name="android:textColorPrimary">@color/forest_green</item>
        <item name="android:textColorSecondary">@color/moss_green</item>
    </style>

    <style name="EventWiseChip" parent="Widget.Material3.Chip.Input">
        <item name="chipBackgroundColor">@color/forest_green</item>
        <item name="android:textColor">@color/lighter_green</item>
        <item name="closeIconTint">@color/lighter_green</item>
    </style>

    <style name="EventWiseDropdown" parent="Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu">
        <item name="boxBackgroundColor">@color/lighter_green</item>
        <item name="boxStrokeColor">@color/forest_green</item>
        <item name="hintTextColor">@color/moss_green</item>
        <item name="android:textColorHint">@color/moss_green</item>
    </style>
</resources>