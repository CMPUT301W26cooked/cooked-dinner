<?xml version="1.0" encoding="utf-8"?>
<!--
    Description: Entrant Events Community Card Widget.
    Author: Luke Forster
    LastRevAuthor: Luke Forster
    Version: 1
    Date: 2026-03-08
    TODO: Need to adjust the event_card_shape to not have radii on corner.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@android:color/transparent"
    android:layout_margin="25dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:background="@drawable/event_card_shape">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
        <ImageView
            android:id="@+id/return_arrow"
            android:layout_width="60dp"
            android:layout_height="30dp"
            android:src="@drawable/return_arrow"
            android:layout_gravity="center"/>
        <TextView
            android:id="@+id/create_event_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Create Event"
            android:textSize="36dp"
            android:textStyle="bold"
            android:textColor="@color/forest_green" />
        </LinearLayout>

        <EditText
            android:id="@+id/input_event_name"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="5dp"
            android:hint="*Title" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/bacon_color"
            android:backgroundTint="@color/bacon_color">

            <EditText
                android:id="@+id/input_event_description"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="5dp"
                android:layout_marginTop="5dp"
                android:background="@null"
                android:gravity="top"
                android:hint="*Description..."
                android:inputType="textMultiLine"
                android:minLines="3"
                android:textSize="17dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/bacon_color"
            android:backgroundTint="@color/bacon_color"
            android:layout_marginTop="10dp">
            <EditText
                android:id="@+id/input_criteria"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="5dp"
                android:layout_marginTop="5dp"
                android:background="@null"
                android:gravity="top"
                android:hint="Criteria / Guidelines..."
                android:inputType="textMultiLine"
                android:minLines="3"
                android:textSize="17dp" />
        </LinearLayout>

        <EditText
            android:id="@+id/input_event_location"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="12dp"
            android:hint="*Location"
            android:textSize="17dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <EditText
                android:id="@+id/input_event_start"
                android:layout_width="155dp"
                android:layout_height="48dp"
                android:layout_marginTop="5dp"
                android:hint="*Event Start"
                android:textSize="17dp" />
            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1"/>

            <EditText
                android:id="@+id/input_event_end"
                android:layout_width="155dp"
                android:layout_height="48dp"
                android:layout_marginTop="5dp"
                android:hint="*Event End"
                android:textSize="17dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <LinearLayout
                android:layout_width="155dp"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <EditText
                    android:id="@+id/input_registration_end"
                    android:layout_width="155dp"
                    android:layout_height="48dp"
                    android:layout_marginTop="5dp"
                    android:hint="*Lottery End"
                    android:textSize="17dp" />

                <EditText
                    android:id="@+id/input_attendance_limit"
                    android:layout_width="155dp"
                    android:layout_height="48dp"
                    android:layout_marginTop="5dp"
                    android:hint="Attendance Limit"
                    android:inputType="number"
                    android:textSize="17dp" />

                <CheckBox
                    android:id="@+id/check_limit_waitlist"
                    android:layout_width="155dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="5dp"
                    android:text="Limit Wait List?" />
                <EditText
                    android:id="@+id/limit_waitlist"
                    android:layout_width="155dp"
                    android:layout_height="48dp"
                    android:layout_marginTop="5dp"
                    android:hint="Wait List Limit"
                    android:inputType="number"
                    android:textSize="17dp" />

                <CheckBox
                    android:id="@+id/check_geo_required"
                    android:layout_width="155dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="5dp"
                    android:layout_marginEnd="5dp"
                    android:text="Entrant Geo location?" />
            </LinearLayout>
            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1"/>
            <LinearLayout
                android:layout_width="155dp"
                android:layout_height="match_parent"
                android:orientation="vertical">

                <ImageView
                    android:id="@+id/input_event_poster"
                    android:layout_width="140dp"
                    android:layout_height="162dp"
                    android:layout_marginHorizontal="8dp"
                    android:layout_marginEnd="5dp"
                    android:layout_marginStart="5dp"
                    android:background="@color/weird_piss"
                    android:contentDescription="Event poster"
                    android:src="@android:drawable/ic_menu_gallery" />
                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1"/>

                <Button
                    android:id="@+id/button_create_event"
                    android:layout_width="140dp"
                    android:layout_height="79dp"
                    android:layout_gravity="end"
                    android:layout_marginEnd="10dp"
                    android:backgroundTint="@color/moss_green"
                    android:text="Create Event"
                    android:textColor="@color/bacon_color"
                    android:textSize="18dp"
                    android:padding="5dp"/>
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</LinearLayout>