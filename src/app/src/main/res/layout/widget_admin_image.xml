<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- Root card container (324x266) -->
    <FrameLayout
        android:id="@+id/event_box_entrant"
        android:layout_width="324dp"
        android:layout_height="266dp">

        <!-- SHADOW LAYER: offset blur shape behind the card -->
        <LinearLayout
            android:id="@+id/shadow_blur"
            android:layout_width="324dp"
            android:layout_height="266dp"
            android:layout_marginStart="26dp"
            android:layout_marginTop="31dp"
            android:background="@drawable/event_card_shape"
            android:orientation="vertical" />

        <!-- FILL + CONTENT: main card background -->
        <LinearLayout
            android:id="@+id/fill"
            android:layout_width="324dp"
            android:layout_height="266dp"
            android:background="@drawable/event_card_shape"
            android:orientation="vertical">

            <!-- GLASS EFFECT overlay -->
            <LinearLayout
                android:id="@+id/glass_effect"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/event_card_shape"
                android:orientation="vertical">

                <!-- TOP SECTION: Title row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingStart="16dp"
                    android:paddingTop="16dp"
                    android:paddingEnd="16dp">

                    <TextView
                        android:id="@+id/image_title"
                        android:layout_width="0dp"
                        android:layout_height="34dp"
                        android:layout_weight="1"
                        android:fontFamily="sans-serif"
                        android:gravity="start|center_vertical"
                        android:text="Image Title"
                        android:textColor="#FF3D4127"
                        android:textSize="20sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- MIDDLE SECTION: Image thumbnail + Delete button -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="160dp"
                    android:orientation="horizontal"
                    android:paddingStart="16dp"
                    android:paddingTop="8dp"
                    android:paddingEnd="12dp"
                    android:paddingBottom="8dp"
                    android:gravity="center_vertical">

                    <!-- Image placeholder box -->
                    <FrameLayout
                        android:id="@+id/image_placeholder"
                        android:layout_width="106dp"
                        android:layout_height="120dp"
                        android:background="#FFF3F6E5">

                        <ImageView
                            android:id="@+id/event_image"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:contentDescription="Event image" />


                    </FrameLayout>

                    <!-- Delete button -->
                    <Button
                        android:id="@+id/delete_button"
                        android:layout_width="120dp"
                        android:layout_height="80dp"
                        android:minHeight="80dp"
                        android:layout_margin="50dp"
                        android:text="Delete"
                        android:textSize="18sp"
                        android:textColor="@color/lighter_green"
                        android:backgroundTint="@color/red"
                        android:padding="5dp" />

                </LinearLayout>

                <!-- BOTTOM SECTION: two rows, each with icon + text -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="12dp">

                    <!-- Row 1: User icon + Org name -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <ImageView
                            android:id="@+id/user_icon"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/profile_icon"
                            android:scaleType="fitXY"
                            android:contentDescription="User profile icon" />

                        <TextView
                            android:id="@+id/img_uploading_org"
                            android:layout_width="wrap_content"
                            android:layout_height="16dp"
                            android:layout_marginStart="4dp"
                            android:fontFamily="sans-serif"
                            android:gravity="center_vertical"
                            android:text="Img Uploading Org"
                            android:textColor="#FF636B2F"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <!-- Row 2: Clock icon + Timestamp -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="20dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="2dp">

                        <ImageView
                            android:id="@+id/icon_clock"
                            android:layout_width="17dp"
                            android:layout_height="17dp"
                            android:src="@drawable/clock"
                            android:scaleType="fitXY"
                            android:contentDescription="Clock icon" />

                        <TextView
                            android:id="@+id/timestampString"
                            android:layout_width="wrap_content"
                            android:layout_height="16dp"
                            android:layout_marginStart="4dp"
                            android:fontFamily="sans-serif"
                            android:gravity="center_vertical"
                            android:text="March 2 2026, 8:00 am"
                            android:textColor="#FF636B2F"
                            android:textSize="10sp" />
                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>
        </LinearLayout>
    </FrameLayout>

</LinearLayout>