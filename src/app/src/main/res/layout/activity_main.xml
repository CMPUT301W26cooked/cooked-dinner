<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/forest_green">


    <LinearLayout
        android:id="@+id/login_buttons_container"
        android:layout_width="0dp"
        android:layout_height="600dp"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center"
        android:background="@color/bacon_color"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/login_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:text="Choose Role"
            android:textColor="@color/forest_green"
            android:textSize="24sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/entrant_button"
            android:layout_width="200dp"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:backgroundTint="@color/moss_green"
            android:text="Entrant"
            android:textColor="@color/bacon_color"/>

        <Button
            android:id="@+id/organizer_button"
            android:layout_width="200dp"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:backgroundTint="@color/moss_green"
            android:text="Organizer"
            android:textColor="@color/bacon_color"/>

        <Button
            android:id="@+id/admin_button"
            android:layout_width="200dp"
            android:layout_height="wrap_content"
            android:backgroundTint="@color/moss_green"
            android:text="Admin"
            android:textColor="@color/bacon_color"/>

    </LinearLayout>

    <FrameLayout
        android:id="@+id/fragment_container"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>