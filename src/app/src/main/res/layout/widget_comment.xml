<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="25dp"
    android:layout_marginTop="10dp"
    android:layout_marginEnd="25dp"
    android:clipChildren="false"
    android:clipToPadding="false">

    <LinearLayout
        android:id="@+id/comment_widget"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/event_card_shape"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Username and Timestamp Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/comment_username"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Username"
                android:textColor="@color/forest_green"
                android:textSize="14sp"
                android:textStyle="bold" />



            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/clock"
                    android:contentDescription="Comment timestamp icon" />

                <TextView
                    android:id="@+id/comment_timestamp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="2026-03-29 12:00:00"
                    android:textColor="@color/moss_green"
                    android:textSize="11sp" />

            </LinearLayout>


        </LinearLayout>

        <TextView
            android:id="@+id/profile_type_string"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Entrant"
            android:textColor="@color/moss_green"
            android:textSize="12sp"
            android:textStyle="bold" />

        <!-- Comment Body -->
        <TextView
            android:id="@+id/comment_body"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="This is the comment body."
            android:textColor="@color/moss_green"
            android:textSize="14sp" />

    </LinearLayout>

    <!-- X button overlaid in top right corner -->
    <ImageButton
        android:id="@+id/delete_comment_button"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:layout_gravity="top|start"
        android:src="@drawable/small_dismiss_icon"
        android:background="@drawable/event_card_shape"
        android:backgroundTint="@color/moss_green"
        android:contentDescription="Delete comment"
        android:layout_margin="-10dp"
        android:padding="6dp" />

</FrameLayout>