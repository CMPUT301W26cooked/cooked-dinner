<?xml version="1.0" encoding="utf-8"?>
<!--
    Description: This XML file contains the entrant selection page for ADA
    Author: Becca Irving
    LastRevAuthor: Becca Irving
    Version: 1
    Date: 2026-03-24
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bacon_color">

    <LinearLayout
        android:id="@+id/top_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:background="@color/moss_green"
        android:orientation="vertical"
        android:paddingVertical="26dp">

        <TextView
            android:id="@+id/header_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Entrant Selection"
            android:textColor="@color/forest_green"
            android:textSize="32sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginStart="19dp"
        android:layout_marginTop="20dp"
        android:layout_marginEnd="19dp"
        android:layout_marginBottom="18dp"
        android:background="@color/lighter_green"
        android:orientation="vertical"
        android:paddingTop="18dp"
        android:paddingBottom="18dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <LinearLayout
            android:id="@+id/selection_header_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="18dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/button_back"
                android:layout_width="40dp"
                android:layout_height="30dp"
                android:src="@drawable/return_arrow"
                android:contentDescription="@string/cd_back_button" />

            <TextView
                android:id="@+id/text_selection_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="Select Entrants"
                android:textColor="@color/forest_green"
                android:textSize="28sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/text_selection_subtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Select entrant ids for this action."
            android:textColor="@color/moss_green"
            android:textSize="14sp"
            android:layout_marginBottom="16dp" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_view_entrant_selection"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingBottom="90dp" />

            <TextView
                android:id="@+id/text_empty_selection"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="No eligible entrants found."
                android:textColor="@color/forest_green"
                android:textSize="22sp"
                android:textStyle="bold"
                android:gravity="center" />

            <Button
                android:id="@+id/button_apply_selection"
                android:layout_width="104dp"
                android:layout_height="48dp"
                android:layout_gravity="bottom|end"
                android:layout_margin="16dp"
                android:text="Apply"
                android:textAllCaps="false"
                android:textColor="@color/lighter_green"
                android:backgroundTint="@color/moss_green"
                android:textSize="18sp" />
        </FrameLayout>

    </LinearLayout>

</LinearLayout>
