<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@android:color/transparent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:background="@drawable/event_card_shape">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
        <TextView
            android:id="@+id/create_event_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Create Event"
            android:textSize="36dp"
            android:textStyle="bold"
            android:textColor="@color/forest_green" />
        </LinearLayout>
        <EditText
            android:id="@+id/input_event_name"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="16dp"
            android:hint="Title" />

        <EditText
            android:id="@+id/input_event_description"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:minLines="3"
            android:gravity="top"
            android:hint="Description"
            android:inputType="textMultiLine" />

        <EditText
            android:id="@+id/input_event_location"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="12dp"
            android:hint="Location" />

        <EditText
            android:id="@+id/input_event_start"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="12dp"
            android:hint="Event Start" />

        <EditText
            android:id="@+id/input_event_end"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="12dp"
            android:hint="Event End" />

        <EditText
            android:id="@+id/input_registration_end"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="12dp"
            android:hint="Registration End" />

        <EditText
            android:id="@+id/input_attendance_limit"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="12dp"
            android:hint="Attendance Limit"
            android:inputType="number" />

        <CheckBox
            android:id="@+id/check_limit_waitlist"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Limit Wait List?" />

        <CheckBox
            android:id="@+id/check_geo_required"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Entrant Geo location?" />

        <Button
            android:id="@+id/button_create_event"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Create Event" />

    </LinearLayout>
</ScrollView>