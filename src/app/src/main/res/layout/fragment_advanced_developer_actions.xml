<?xml version="1.0" encoding="utf-8"?>
<!--
    Description: This XML file contains the advanced developer actions page for organizers.
    Author: Becca Irving
    LastRevAuthor: Becca Irving
    Version: 1
    Date: 2026-03-25
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bacon_color">

    <LinearLayout
        android:id="@+id/top_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:background="@color/moss_green"
        android:orientation="vertical"
        android:paddingVertical="26dp">

        <TextView
            android:id="@+id/header_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Advanced Developer Actions"
            android:textColor="@color/forest_green"
            android:textSize="28sp"
            android:textStyle="bold" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="19dp"
            android:layout_marginTop="20dp"
            android:layout_marginEnd="19dp"
            android:layout_marginBottom="18dp"
            android:background="@color/lighter_green"
            android:orientation="vertical"
            android:paddingTop="18dp"
            android:paddingBottom="18dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <LinearLayout
                android:id="@+id/advanced_actions_header_row"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/button_back"
                    android:layout_width="40dp"
                    android:layout_height="30dp"
                    android:src="@drawable/return_arrow"
                    android:contentDescription="@string/cd_back_button" />

                <TextView
                    android:id="@+id/text_advanced_actions_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:text="Advanced Developer Actions"
                    android:textColor="@color/forest_green"
                    android:textSize="28sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:id="@+id/text_warning"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Warning these actions go against the intended function of the app and bypass usual user permissions"
                android:textColor="@color/red"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <TextView
                android:id="@+id/text_manual_actions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Manually..."
                android:textColor="@color/forest_green"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="18dp" />

            <Button
                android:id="@+id/button_waitlist_entrants"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="16dp"
                android:text="Waitlist Entrants"
                android:textAllCaps="false"
                android:textColor="@color/lighter_green"
                android:backgroundTint="@color/moss_green"
                android:textSize="18sp" />

            <Button
                android:id="@+id/button_remove_waitlist_entrants"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="16dp"
                android:text="Remove Waitlist Entrants"
                android:textAllCaps="false"
                android:textColor="@color/lighter_green"
                android:backgroundTint="@color/moss_green"
                android:textSize="18sp" />

            <Button
                android:id="@+id/button_invite_entrants"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="16dp"
                android:text="Invite Entrants"
                android:textAllCaps="false"
                android:textColor="@color/lighter_green"
                android:backgroundTint="@color/moss_green"
                android:textSize="18sp" />

            <Button
                android:id="@+id/button_remove_invite_entrants"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="16dp"
                android:text="Remove Invited Entrants"
                android:textAllCaps="false"
                android:textColor="@color/lighter_green"
                android:backgroundTint="@color/moss_green"
                android:textSize="18sp" />

            <Button
                android:id="@+id/button_enroll_entrants"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="16dp"
                android:text="Enroll Entrants"
                android:textAllCaps="false"
                android:textColor="@color/lighter_green"
                android:backgroundTint="@color/moss_green"
                android:textSize="18sp" />

            <Button
                android:id="@+id/button_remove_enroll_entrants"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Remove Enrolled Entrants"
                android:textAllCaps="false"
                android:textColor="@color/lighter_green"
                android:backgroundTint="@color/moss_green"
                android:textSize="18sp" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>
