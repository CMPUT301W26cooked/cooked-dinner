<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bacon_color">

    <LinearLayout
        android:id="@+id/top_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:background="@color/moss_green"
        android:orientation="vertical"
        android:paddingVertical="26dp">

        <TextView
            android:id="@+id/header_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Your Events"
            android:textColor="@color/forest_green"
            android:textSize="32sp"
            android:textStyle="bold" />
    </LinearLayout>

    <ScrollView
        xmlns:android="http://schemas.android.com/apk/res/android"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginStart="19dp"
            android:layout_marginTop="20dp"
            android:layout_marginEnd="19dp"
            android:layout_marginBottom="18dp"
            android:background="@color/lighter_green"
            android:orientation="vertical"
            android:paddingTop="18dp"
            android:paddingBottom="18dp">


            <LinearLayout
                android:id="@+id/view_entrants_header_row"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="11dp"
                android:layout_marginEnd="11dp"
                android:layout_marginBottom="20dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/button_back"
                    android:layout_width="40dp"
                    android:layout_height="30dp"
                    android:src="@drawable/return_arrow"
                    android:contentDescription="Back" />

                <TextView
                    android:id="@+id/text_view_entrants_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:text="View Entrants"
                    android:textColor="@color/forest_green"
                    android:textSize="36sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:id="@+id/text_view_entrants_subtitle"
                android:layout_width="209dp"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="14dp"
                android:gravity="center"
                android:text="Select the type of entrants you would like to view for your event"
                android:textColor="@color/moss_green"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/text_view_entrants_info"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:layout_marginStart="18dp"
                android:layout_marginEnd="18dp"
                android:text="If you enabled geo location, select Waitlisted to also view a map of where entrants joined from\n\nSelect Registered to also export a CSV of registered attendees"
                android:textColor="@color/moss_green"
                android:textSize="12sp" />

            <LinearLayout
                android:id="@+id/filter_row_one"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_marginStart="11dp"
                android:layout_marginEnd="11dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/button_waitlisted"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="13dp"
                    android:text="Waitlisted"
                    android:textAllCaps="false"
                    android:textColor="@color/lighter_green"
                    android:backgroundTint="@color/moss_green"
                    android:textSize="18sp" />

                <Button
                    android:id="@+id/button_invitees"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginStart="13dp"
                    android:text="Invitees"
                    android:textAllCaps="false"
                    android:textColor="@color/lighter_green"
                    android:backgroundTint="@color/moss_green"
                    android:textSize="18sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/filter_row_two"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:layout_marginStart="11dp"
                android:layout_marginEnd="11dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/button_canceled"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="13dp"
                    android:text="Canceled"
                    android:textAllCaps="false"
                    android:textColor="@color/lighter_green"
                    android:backgroundTint="@color/moss_green"
                    android:textSize="18sp" />

                <Button
                    android:id="@+id/button_registered"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginStart="13dp"
                    android:text="Registered"
                    android:textAllCaps="false"
                    android:textColor="@color/lighter_green"
                    android:backgroundTint="@color/moss_green"
                    android:textSize="18sp" />
            </LinearLayout>

            <Button
                android:id="@+id/button_export_csv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="18dp"
                android:backgroundTint="@color/moss_green"
                android:paddingStart="24dp"
                android:paddingTop="8dp"
                android:paddingEnd="24dp"
                android:paddingBottom="8dp"
                android:text="Export CSV"
                android:textAllCaps="false"
                android:textColor="@color/lighter_green"
                android:textSize="14sp"
                android:visibility="gone" />

            <FrameLayout
                android:id="@+id/map_container"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                >
                <LinearLayout
                    android:id="@+id/map_view"
                    android:layout_width="match_parent"
                    android:layout_height="100dp"
                    android:layout_marginTop="18dp"
                    android:layout_marginStart="11dp"
                    android:layout_marginEnd="11dp"
                    android:orientation="vertical"
                    android:background="@color/moss_green">
                    <androidx.fragment.app.FragmentContainerView
                        android:id="@+id/map"
                        android:name="com.google.android.gms.maps.SupportMapFragment"
                        android:layout_marginTop="5dp"
                        android:layout_marginStart="5dp"
                        android:layout_marginEnd="5dp"
                        android:layout_marginBottom="5dp"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:background="@color/white" />
                </LinearLayout>
            </FrameLayout>

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginTop="24dp">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recycler_view_entrants"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:paddingBottom="14dp" />

                <TextView
                    android:id="@+id/text_empty_entrants"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="Nothing to see here."
                    android:textColor="@color/forest_green"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:visibility="gone" />
            </FrameLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
