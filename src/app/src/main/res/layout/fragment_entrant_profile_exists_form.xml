<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bacon_color">

    <include
        android:id="@+id/profile_top_bar"
        layout="@layout/widget_entrant_profile_top_bar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <include
        android:id="@+id/white_inner_background"
        layout="@layout/fragment_white_inner_background"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="18dp"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="18dp"
        android:layout_marginBottom="16dp"
        app:layout_constraintTop_toBottomOf="@id/profile_top_bar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/profile_form_helper_text"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="34dp"
        android:layout_marginTop="18dp"
        android:layout_marginEnd="34dp"
        android:gravity="center"
        android:text="This information is used to auto fill your registration"
        android:textColor="@color/moss_green"
        android:textSize="12sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="@id/white_inner_background"
        app:layout_constraintStart_toStartOf="@id/white_inner_background"
        app:layout_constraintEnd_toEndOf="@id/white_inner_background" />

    <TextView
        android:id="@+id/profile_form_instruction_text"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="46dp"
        android:layout_marginTop="24dp"
        android:layout_marginEnd="46dp"
        android:gravity="center"
        android:text="Fill in your details below.\nValidate at each step."
        android:textColor="@color/forest_green"
        android:textSize="20sp"
        app:layout_constraintTop_toBottomOf="@id/profile_form_helper_text"
        app:layout_constraintStart_toStartOf="@id/white_inner_background"
        app:layout_constraintEnd_toEndOf="@id/white_inner_background" />

    <LinearLayout
        android:id="@+id/name_field_block"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginTop="26dp"
        android:layout_marginEnd="20dp"
        android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@id/profile_form_instruction_text"
        app:layout_constraintStart_toStartOf="@id/white_inner_background"
        app:layout_constraintEnd_toEndOf="@id/white_inner_background">

        <LinearLayout
            android:id="@+id/name_field_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <EditText
                android:id="@+id/edit_text_profile_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:hint="*Name"
                android:inputType="textPersonName"
                android:paddingBottom="8dp"
                android:textColor="@color/forest_green"
                android:textColorHint="@color/moss_green"
                android:textSize="17sp" />

            <ImageView
                android:id="@+id/image_name_validation_status"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_marginStart="12dp"
                android:visibility="invisible"
                android:contentDescription="Name validation status" />
        </LinearLayout>

        <View
            android:id="@+id/profile_name_underline"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/moss_green" />

        <TextView
            android:id="@+id/text_name_error"
            android:layout_width="match_parent"
            android:layout_height="18dp"
            android:layout_marginTop="4dp"
            android:text=""
            android:textColor="@color/red"
            android:textSize="12sp"
            android:visibility="invisible" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/email_field_block"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginTop="14dp"
        android:layout_marginEnd="20dp"
        android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@id/name_field_block"
        app:layout_constraintStart_toStartOf="@id/white_inner_background"
        app:layout_constraintEnd_toEndOf="@id/white_inner_background">

        <LinearLayout
            android:id="@+id/email_field_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <EditText
                android:id="@+id/edit_text_profile_email"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:hint="*Email"
                android:inputType="textEmailAddress"
                android:paddingBottom="8dp"
                android:textColor="@color/forest_green"
                android:textColorHint="@color/moss_green"
                android:textSize="17sp" />

            <ImageView
                android:id="@+id/image_email_validation_status"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_marginStart="12dp"
                android:visibility="invisible"
                android:contentDescription="Email validation status" />
        </LinearLayout>

        <View
            android:id="@+id/profile_email_underline"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/moss_green" />

        <TextView
            android:id="@+id/text_email_error"
            android:layout_width="match_parent"
            android:layout_height="18dp"
            android:layout_marginTop="4dp"
            android:text=""
            android:textColor="@color/red"
            android:textSize="12sp"
            android:visibility="invisible" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/phone_field_block"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginTop="14dp"
        android:layout_marginEnd="20dp"
        android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@id/email_field_block"
        app:layout_constraintStart_toStartOf="@id/white_inner_background"
        app:layout_constraintEnd_toEndOf="@id/white_inner_background">

        <LinearLayout
            android:id="@+id/phone_field_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <EditText
                android:id="@+id/edit_text_profile_phone"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:hint="Phone Number"
                android:inputType="phone"
                android:paddingBottom="8dp"
                android:textColor="@color/forest_green"
                android:textColorHint="@color/moss_green"
                android:textSize="17sp" />

            <ImageView
                android:id="@+id/image_phone_validation_status"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_marginStart="12dp"
                android:visibility="invisible"
                android:contentDescription="Phone validation status" />
        </LinearLayout>

        <View
            android:id="@+id/profile_phone_underline"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/moss_green" />

        <TextView
            android:id="@+id/text_phone_error"
            android:layout_width="match_parent"
            android:layout_height="18dp"
            android:layout_marginTop="4dp"
            android:text=""
            android:textColor="@color/red"
            android:textSize="12sp"
            android:visibility="invisible" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layout_receive_notifications"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintTop_toBottomOf="@id/phone_field_block"
        app:layout_constraintStart_toStartOf="@id/white_inner_background"
        app:layout_constraintEnd_toEndOf="@id/white_inner_background">

        <ImageView
            android:id="@+id/image_receive_notifications_checkbox"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/profile_checkbox_checked"
            android:contentDescription="Receive notifications checkbox" />

        <TextView
            android:id="@+id/text_receive_notifications"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="Receive Notifications"
            android:textColor="@color/forest_green"
            android:textSize="20sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/profile_action_area"
        android:layout_width="0dp"
        android:layout_height="190dp"
        android:layout_marginStart="22dp"
        android:layout_marginTop="18dp"
        android:layout_marginEnd="22dp"
        android:layout_marginBottom="18dp"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:weightSum="3"
        app:layout_constraintTop_toBottomOf="@id/layout_receive_notifications"
        app:layout_constraintBottom_toBottomOf="@id/white_inner_background"
        app:layout_constraintStart_toStartOf="@id/white_inner_background"
        app:layout_constraintEnd_toEndOf="@id/white_inner_background">

        <FrameLayout
            android:id="@+id/create_profile_button_container"
            android:layout_width="240dp"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="6dp"
            android:background="@drawable/profile_button_shape">

            <Button
                android:id="@+id/btn_submit_profile"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@android:color/transparent"
                android:text="Create Profile"
                android:textAllCaps="false"
                android:textColor="@color/lighter_green"
                android:textSize="20sp"
                android:enabled="false"
                android:alpha="1.0" />
        </FrameLayout>

        <FrameLayout
            android:id="@+id/cancel_profile_button_container"
            android:layout_width="240dp"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="6dp"
            android:background="@drawable/profile_cancel_button_shape">

            <Button
                android:id="@+id/btn_cancel_profile"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@android:color/transparent"
                android:text="Cancel"
                android:textAllCaps="false"
                android:textColor="@color/lighter_green"
                android:textSize="20sp"
                android:alpha="1.0" />
        </FrameLayout>

        <FrameLayout
            android:id="@+id/delete_profile_button_container"
            android:layout_width="240dp"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="6dp"
            android:background="@drawable/profile_cancel_button_shape"
            android:visibility="gone">

            <Button
                android:id="@+id/btn_delete_profile"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@android:color/transparent"
                android:text="Delete Profile"
                android:textAllCaps="false"
                android:textColor="@color/lighter_green"
                android:textSize="20sp" />
        </FrameLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
