<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/top_bar"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/moss_green"
    android:gravity="center"
    android:orientation="horizontal"
    android:paddingTop="18dp"
    android:paddingBottom="14dp">

    <LinearLayout
        android:id="@+id/profile_switcher"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:clickable="true"
        android:focusable="true"
        android:padding="4dp">

        <TextView
            android:id="@+id/top_bar_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Your Profile"
            android:textColor="@color/forest_green"
            android:textSize="32sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/profile_switcher_arrow"
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:layout_marginStart="6dp"
            android:contentDescription="Switch profile type"
            android:src="@drawable/profile_dropdown" />

    </LinearLayout>

</LinearLayout>
