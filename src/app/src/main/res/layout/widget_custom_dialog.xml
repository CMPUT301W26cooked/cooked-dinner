<?xml version="1.0" encoding="utf-8"?>
<!--
    Description: Reusable custom dialog widget for organizer action confirmations and messages.
    Author: Becca Irving
    LastRevAuthor: Becca Irving
    Version: 1
    Date: 2026-03-27
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/dialog_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="12dp"
    android:background="@drawable/widget_custom_dialog_background"
    android:orientation="vertical"
    android:paddingStart="22dp"
    android:paddingTop="20dp"
    android:paddingEnd="22dp"
    android:paddingBottom="18dp">

    <TextView
        android:id="@+id/dialog_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Dialog Title"
        android:textColor="@color/forest_green"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/dialog_message"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Dialog message goes here."
        android:textColor="@color/moss_green"
        android:textSize="16sp" />

    <LinearLayout
        android:id="@+id/dialog_button_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <Button
            android:id="@+id/dialog_negative_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="10dp"
            android:backgroundTint="@color/red"
            android:text="No"
            android:textAllCaps="false"
            android:textColor="@color/lighter_green"
            android:textSize="15sp" />

        <Button
            android:id="@+id/dialog_positive_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:backgroundTint="@color/moss_green"
            android:text="Yes"
            android:textAllCaps="false"
            android:textColor="@color/lighter_green"
            android:textSize="15sp" />
    </LinearLayout>

</LinearLayout>
