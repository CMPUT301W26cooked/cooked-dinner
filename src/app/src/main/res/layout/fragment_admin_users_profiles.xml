<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <LinearLayout
        android:id="@+id/top_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/moss_green"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/primary_tab"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="29dp"
            android:layout_marginBottom="9dp"
            android:layout_marginHorizontal="39dp"
            android:text="Profiles"
            android:textColor="@color/weird_piss"
            android:textSize="24sp"
            android:textStyle="bold" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/secondary_tab"
            android:layout_width="170dp"
            android:layout_height="wrap_content"
            android:layout_marginBottom="9dp"
            android:layout_marginHorizontal="39dp"
            android:text="Organizations"
            android:textColor="@color/forest_green"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_gravity="bottom"/>
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/list_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@color/bacon_color" />

</LinearLayout>