<?xml version="1.0" encoding="utf-8"?>
<!--
    Description: This XML file contains the event actions page
    Author: Becca Irving
    LastRevAuthor: Becca Irving
    Version: 2
    Date: 2026-03-24
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bacon_color">

    <LinearLayout
        android:id="@+id/top_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:background="@color/moss_green"
        android:orientation="vertical"
        android:paddingVertical="26dp">

        <TextView
            android:id="@+id/header_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Entrant Actions"
            android:textColor="@color/forest_green"
            android:textSize="32sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginStart="19dp"
        android:layout_marginTop="20dp"
        android:layout_marginEnd="19dp"
        android:layout_marginBottom="18dp"
        android:background="@color/lighter_green"
        android:orientation="vertical"
        android:paddingTop="18dp"
        android:paddingBottom="18dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <LinearLayout
            android:id="@+id/entrant_actions_header_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="28dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/button_back"
                android:layout_width="40dp"
                android:layout_height="30dp"
                android:src="@drawable/return_arrow"
                android:contentDescription="@string/cd_back_button" />

            <TextView
                android:id="@+id/text_entrant_actions_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="Entrant Actions"
                android:textColor="@color/forest_green"
                android:textSize="36sp"
                android:textStyle="bold" />
        </LinearLayout>

        <Button
            android:id="@+id/button_view_entrants"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="18dp"
            android:text="View Entrants"
            android:textAllCaps="false"
            android:textColor="@color/lighter_green"
            android:backgroundTint="@color/moss_green"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/text_draw_entrants_reason"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:text="* no entrants in waitlist"
            android:textColor="@android:color/darker_gray"
            android:textSize="12sp"
            android:visibility="gone" />

        <Button
            android:id="@+id/button_draw_entrants"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="18dp"
            android:text="Draw Entrants"
            android:textAllCaps="false"
            android:textColor="@color/lighter_green"
            android:backgroundTint="@color/moss_green"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/text_redraw_entrants_reason"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:text="* no open spots in this event"
            android:textColor="@android:color/darker_gray"
            android:textSize="12sp"
            android:visibility="gone" />

        <Button
            android:id="@+id/button_redraw_entrants"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="18dp"
            android:text="Re-draw Entrants"
            android:textAllCaps="false"
            android:textColor="@color/lighter_green"
            android:backgroundTint="@color/moss_green"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/text_cancel_invitees_reason"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:text="* no invited entrants at this time"
            android:textColor="@android:color/darker_gray"
            android:textSize="12sp"
            android:visibility="gone" />

        <Button
            android:id="@+id/button_cancel_invitees"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="18dp"
            android:text="Cancel Invitees"
            android:textAllCaps="false"
            android:textColor="@color/lighter_green"
            android:backgroundTint="@color/moss_green"
            android:textSize="18sp" />

        <Button
            android:id="@+id/button_advanced_developer_actions"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Advanced Developer Actions"
            android:textAllCaps="false"
            android:textColor="@color/lighter_green"
            android:backgroundTint="@color/forest_green"
            android:textSize="18sp" />

    </LinearLayout>

</LinearLayout>
